@{
    ViewData["Title"] = "Nuevo Turno";
}
@section Styles {
    <link rel="stylesheet" href="~/css/new-turn.css" asp-append-version="true" />
}

<section class="new-turn-page">
    <div class="new-turn-form-panel">
        <div class="new-turn-hero">
            <div class="new-turn-kicker">Autoservicio</div>
            <h1 class="panel-heading">Solicitar <em>nuevo turno</em></h1>
            <p class="panel-subtitle">Ingresa tus datos y recibe tu ticket al instante.</p>
        </div>

        <form class="new-turn-form-card" asp-controller="Turn" asp-action="RequestTurn" method="post">
            <div class="form-step-bar">
                <div class="form-step active"><div class="form-step-dot">1</div><div class="form-step-label">Usuario</div></div>
                <div class="form-step-line"></div>
                <div class="form-step"><div class="form-step-dot">2</div><div class="form-step-label">Ticket</div></div>
            </div>

            <label class="field-label" for="fullName">Nombre completo</label>
            <input class="input" id="fullName" name="fullName" required placeholder="Ej: Daniela Martinez" />

            <label class="field-label" for="documentNumber">Documento</label>
            <input class="input" id="documentNumber" name="documentNumber" required placeholder="Ej: 7823014" />

            <button class="btn btn--primary btn--lg" type="submit">Generar Turno</button>
        </form>

        <div class="new-turn-helper-row" aria-label="Informacion de ayuda">
            <div class="new-turn-helper-item">
                <strong>1</strong>
                <span>Registra tus datos</span>
            </div>
            <div class="new-turn-helper-item">
                <strong>2</strong>
                <span>Recibe tu ticket</span>
            </div>
            <div class="new-turn-helper-item">
                <strong>3</strong>
                <span>Espera tu llamado</span>
            </div>
        </div>
    </div>
</section>
