@model IEnumerable<queue_management.Models.Turn>
@using queue_management.Models
@{
    ViewData["Title"] = "Cola de Turnos";
    var current = Model.FirstOrDefault(t => t.Status == TurnStatus.InService);
    var pending = Model.Where(t => t.Status == TurnStatus.Pending).OrderBy(t => t.CreatedAt).ToList();
    var waiting = Model.Where(t => t.Status == TurnStatus.Waiting).OrderBy(t => t.CreatedAt).ToList();
}
@section Styles {
    <link rel="stylesheet" href="~/css/turn-queue.css" asp-append-version="true" />
    <style>
        /* Barra de estado SignalR */
        .signalr-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: .75rem;
            font-weight: 600;
        }
        .signalr-connected    { background: #d1fae5; color: #065f46; }
        .signalr-connecting   { background: #fef3c7; color: #92400e; }
        .signalr-disconnected { background: #fee2e2; color: #991b1b; }

        /* Animación de turno llamado */
        @@keyframes pulse-ticket {
            0%, 100% { transform: scale(1); }
            50%       { transform: scale(1.06); }
        }
        .queue-current-number.pulse {
            animation: pulse-ticket .6s ease-in-out 3;
        }
    </style>
}

<section class="queue-page">

    <header class="queue-topbar">
        <div class="queue-topbar-brand">Sistema <span>de turnos</span></div>
        <div class="queue-topbar-clock" id="live-clock">@DateTime.Now.ToString("HH:mm:ss")</div>
        <div class="queue-topbar-status">
            <span class="signalr-status signalr-connecting" id="signalr-status">⬤ Conectando…</span>
        </div>
    </header>

    <main class="queue-main">

        <section class="queue-now-serving">
            <div>
                <p class="queue-section-label">Turno actual</p>

                <div class="queue-current-card">
                    <div class="queue-current-number" id="current-ticket">
                        @(current?.TicketCode ?? "---")
                    </div>
                    <div class="queue-current-meta">
                        <div class="queue-current-service" id="current-name">
                            @(current?.User?.FullName ?? "Esperando llamado")
                        </div>
                        <div class="queue-current-module">Modulo asesor</div>
                    </div>
                    <div class="queue-current-highlight">En atencion</div>
                </div>
            </div>

            <div class="queue-announce-bar">
                <div class="queue-announce-waves">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>
                <div class="queue-announce-text" id="sound-status">Sonido listo para activar</div>
                <button class="queue-sound-button" id="enable-sound" type="button">Activar sonido</button>
            </div>

            <aside class="queue-list-panel">
                <div class="queue-list-header">
                    <p class="queue-section-label">Turnos en cola</p>
                    <span class="queue-list-count" id="queue-count">
                        @(pending.Count + waiting.Count) pendientes
                    </span>
                </div>
                <div class="queue-list-scroll" id="queue-list">
                    @foreach (var turn in pending.Concat(waiting))
                    {
                        <div class="queue-item">
                            <strong class="queue-item-number">@turn.TicketCode</strong>
                            <span class="queue-item-service">@turn.User?.FullName</span>
                            <span class="badge @(turn.Status == TurnStatus.Pending ? "badge--pending" : "badge--waiting")">
                                @turn.Status
                            </span>
                        </div>
                    }
                </div>
            </aside>
        </section>

        <aside class="waiting-media-panel">
            <video class="waiting-room-video"
                   autoplay
                   muted
                   loop
                   playsinline
                   preload="auto"
                   poster="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1400&q=80">
                <source src="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4" type="video/mp4" />
            </video>
        </aside>

    </main>
</section>

@section Scripts {
<!--
    ╔══════════════════════════════════════════════════════╗
    ║           SIGNALR — WAITING ROOM                      ║
    ╚══════════════════════════════════════════════════════╝

    Diferencia con Advisor:
    - Aquí NO hacemos location.reload() porque la pantalla de sala
      de espera es una PANTALLA PÚBLICA (proyector/TV) que no debe
      parpadear con recargas completas.
    - En cambio, hacemos fetch a /api/queue para obtener solo los datos
      y actualizamos el DOM directamente (actualización parcial).
    - El reloj también se actualiza con JS cada segundo.
-->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"
        crossorigin="anonymous"
        referrerpolicy="no-referrer"></script>
<script>
(function () {
    // ── Reloj en vivo ─────────────────────────────────────────────
    // El reloj del servidor es estático (renderizado una vez en Razor).
    // Lo reemplazamos con JS para que se actualice cada segundo.
    const clockEl = document.getElementById("live-clock");
    function updateClock() {
        const now = new Date();
        clockEl.textContent = now.toLocaleTimeString("es-CO", { hour12: false });
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ── Referencias DOM ───────────────────────────────────────────
    const currentTicketEl = document.getElementById("current-ticket");
    const currentNameEl   = document.getElementById("current-name");
    const queueCountEl    = document.getElementById("queue-count");
    const queueListEl     = document.getElementById("queue-list");
    const statusEl        = document.getElementById("signalr-status");
    const soundStatusEl   = document.getElementById("sound-status");
    const enableSoundBtn  = document.getElementById("enable-sound");
    let audioContext;
    let soundEnabled = false;

    function setStatus(state) {
        statusEl.className = "signalr-status signalr-" + state;
        const labels = { connected: "⬤ En vivo", connecting: "⬤ Conectando…", disconnected: "⬤ Sin conexión" };
        statusEl.textContent = labels[state] ?? state;
    }

    function ensureAudio() {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) return false;
        audioContext ??= new AudioContext();
        if (audioContext.state === "suspended") {
            audioContext.resume();
        }
        soundEnabled = true;
        soundStatusEl.textContent = "Sonido activo";
        enableSoundBtn.hidden = true;
        return true;
    }

    function playTurnSound() {
        if (!soundEnabled || !audioContext) return;

        const now = audioContext.currentTime;
        const notes = [880, 1174.66, 1567.98];
        notes.forEach((frequency, index) => {
            const oscillator = audioContext.createOscillator();
            const gain = audioContext.createGain();
            const start = now + index * 0.16;

            oscillator.type = "sine";
            oscillator.frequency.setValueAtTime(frequency, start);
            gain.gain.setValueAtTime(0.0001, start);
            gain.gain.exponentialRampToValueAtTime(0.22, start + 0.02);
            gain.gain.exponentialRampToValueAtTime(0.0001, start + 0.14);

            oscillator.connect(gain);
            gain.connect(audioContext.destination);
            oscillator.start(start);
            oscillator.stop(start + 0.16);
        });
    }

    enableSoundBtn.addEventListener("click", ensureAudio);

    // ── Actualización parcial del DOM ─────────────────────────────
    // Llamada al API que ya existe en tu proyecto (QueueController).
    // No recarga la página — solo actualiza los elementos necesarios.
    async function refreshQueue() {
        try {
            const res  = await fetch("/api/queue");
            if (!res.ok) return;
            const data = await res.json();

            // Turno actual
            const newTicket = data.current?.ticketCode ?? "---";
            const newName   = data.current?.user?.fullName ?? "Esperando llamado";

            // Si el turno cambió, animar para llamar la atención
            if (currentTicketEl.textContent.trim() !== newTicket) {
                currentTicketEl.textContent = newTicket;
                currentNameEl.textContent   = newName;
                playTurnSound();

                // ← Clase "pulse" agrega animación CSS por 3 pulsos
                currentTicketEl.classList.remove("pulse");
                void currentTicketEl.offsetWidth; // reflow para reiniciar animación
                currentTicketEl.classList.add("pulse");
            }

            // Lista de espera
            const total = data.totalWaiting;
            queueCountEl.textContent = total + " pendiente" + (total !== 1 ? "s" : "");

            // Reconstruir lista de turnos en espera
            queueListEl.innerHTML = data.waiting.map(t => `
                <div class="queue-item">
                    <strong class="queue-item-number">${t.ticketCode}</strong>
                    <span class="queue-item-service">${t.user?.fullName ?? ""}</span>
                    <span class="badge ${t.status === "Pending" ? "badge--pending" : "badge--waiting"}">${t.status}</span>
                </div>
            `).join("");

        } catch (err) {
            console.warn("Error al actualizar cola:", err);
        }
    }

    // ── Conexión SignalR ──────────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/queueHub")
        .withAutomaticReconnect([0, 2000, 10000, 30000])
        .build();

    // Cuando el servidor notifica un cambio, actualizamos sin recargar
    connection.on("QueueUpdated", () => refreshQueue());

    connection.onreconnecting(() => setStatus("connecting"));
    connection.onreconnected(()  => { setStatus("connected"); refreshQueue(); });
    connection.onclose(()        => setStatus("disconnected"));

    connection.start()
        .then(() => {
            setStatus("connected");
            return connection.invoke("JoinGroup", "waitingRoom");
        })
        .catch(err => {
            setStatus("disconnected");
            console.error("SignalR error:", err);
            // Fallback: si SignalR no conecta, hacer polling cada 8s
            setInterval(refreshQueue, 8000);
        });
})();
</script>
}
