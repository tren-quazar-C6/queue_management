@{
    ViewData["Title"] = "Ticket";
    var fullName = TempData["FullName"]?.ToString() ?? "N/A";
    var documentNumber = TempData["DocumentNumber"]?.ToString() ?? "N/A";
    var ticketCode = TempData["TicketCode"]?.ToString() ?? "N/A";
}
@section Styles {
    <link rel="stylesheet" href="~/css/new-turn.css" asp-append-version="true" />
}

@* @{ *@
@*     var fullName = TempData["FullName"]; *@
@*     var documentNumber = TempData["DocumentNumber"]; *@
@*     var ticketCode = TempData["TicketCode"]; *@
@* } *@

<section class="new-turn-page ticket-result-page">
    <div class="new-turn-form-panel">
        <div class="new-turn-hero">
            <div class="new-turn-kicker">Ticket listo</div>
            <h1 class="panel-heading">Turno generado</h1>
            <p class="panel-subtitle">Conserva este numero y espera tu llamado en sala.</p>
        </div>
        <div class="new-turn-form-card ticket-actions-card">
            <a class="btn btn--secondary" asp-controller="Turn" asp-action="Kiosk">Generar otro turno</a>
            <a class="btn btn--ghost" asp-controller="Turn" asp-action="WaitingRoom">Ir a sala de espera</a>
        </div>
    </div>

    <aside class="ticket-panel">
        <article class="ticket-card ticket-result-card">
            <p class="card-title">Tu ticket</p>
            <div class="ticket-number">@ticketCode</div>
            <span class="badge badge--pending">Pendiente</span>
        </article>
    </aside>
</section>

<style>
    @@media print {
        body * { visibility: hidden; }
        #ticket, #ticket * { visibility: visible; }
        #ticket { position: absolute; left: 0; top: 0; }
    }
</style>

<div id="ticket">
    <pre>
==================
      TURNO       
==================
Nombre: @fullName
Doc:    @documentNumber
Ticket: @ticketCode
==================
 Por favor espere 
     su turno     
==================
    </pre>
</div>

<script src="https://cdn.jsdelivr.net/npm/qz-tray/qz-tray.min.js"></script>

<script>
    window.onload = async function () {
        await qz.websocket.connect();

        var config = qz.configs.create("Printer USB Printer Port");

        var data = [{
            type: 'raw',
            format: 'plain',
            data: '==================\n' +
                  '      TURNO       \n' +
                  '==================\n' +
                  'Nombre: @fullName\n' +
                  'Doc:    @documentNumber\n' +
                  'Ticket: @ticketCode\n' +
                  '==================\n' +
                  ' Por favor espere \n' +
                  '     su turno     \n' +
                  '==================\n' +
                  '\n\n\n'
        }];

        await qz.print(config, data);
        await qz.websocket.disconnect();
    };
</script>
